.page {
  padding-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
  font-size: 28rpx;
}

.btn {
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
  color: #111;
  font-size: 28rpx;
}

.hint {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.error {
  margin-top: 12rpx;
  color: #c5221f;
  font-size: 26rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.poi,
.tip {
  padding: 18rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.poi {
  width: 100%;
  text-align: left;
  background: transparent;
  border-radius: 12rpx;
}

.poi::after {
  border: none;
}

.poi-hover {
  background: #eef2f7;
}

.poi-name,
.tip-name {
  font-size: 30rpx;
  font-weight: 650;
}

.poi-sub,
.tip-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.empty,
.loading {
  padding: 18rpx 0;
  font-size: 26rpx;
}

