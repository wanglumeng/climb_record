.page {
  padding-bottom: 32rpx;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.filters {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f3f5;
  font-size: 24rpx;
  color: #111;
  line-height: 1.2;
}

.count {
  margin-left: auto;
  font-size: 24rpx;
}

.btn {
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  background: #f2f3f5;
  color: #111;
  font-size: 28rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.empty-desc {
  margin-bottom: 20rpx;
}

.item {
  margin-top: 0;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 650;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-date {
  font-size: 24rpx;
  flex: none;
}

.item-note {
  margin-top: 8rpx;
  font-size: 26rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

